# Public browser-safe Storefront API values.
# Add these to Vercel after the Shopify Storefront token is created.
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_API_TOKEN=shpat_or_public_storefront_token
VITE_SHOPIFY_API_VERSION=2026-07
VITE_SHOPIFY_CUSTOMER_ACCOUNT_URL=https://your-store.myshopify.com/account
VITE_SHOPIFY_CUSTOMER_ACCOUNT_LOGOUT_URL=https://your-store.myshopify.com/account/logout

# Private server-only Customer Account API values.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=
SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=https://www.pokemon-sa.com/api/shopify/customer/callback
SHOPIFY_CUSTOMER_ACCOUNT_LOGOUT_REDIRECT_URI=https://www.pokemon-sa.com/
SHOPIFY_CUSTOMER_SESSION_SECRET=

# Private local-only Admin API values for the import script.
# Never prefix the Admin API token with VITE_ and never expose it in the browser.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_your_admin_api_token
SHOPIFY_API_VERSION=2026-07
SHOPIFY_DEFAULT_INVENTORY=25
